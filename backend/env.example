# Environment Configuration for Go Postal SD
# Copy this file to .env and update the values for your environment

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Frontend URL - This is used in emails for password reset and verification links
# Development - NO trailing slash!
FRONTEND_URL=http://localhost:5173

# Production (uncomment and update for production)
# FRONTEND_URL=https://gopostalsd.com

# Staging (uncomment and update for staging)
# FRONTEND_URL=https://staging.gopostalsd.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL
# Development (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/gopostalsd_dev
# Format: postgresql://username:password@host:port/database_name

# SQLite alternative (if needed)
# DATABASE_URL=sqlite:///instance/gopostalsd.db

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Choose one email provider:

# Option 1: MailerSend (Recommended for production)
# MAILERSEND_API_KEY=your_mailersend_api_key_here
# MAILERSEND_FROM_EMAIL=noreply@gopostalsd.com
# MAILERSEND_FROM_NAME=Go Postal SD

# Option 2: SMTP (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@gopostalsd.com
SMTP_FROM_NAME=Go Postal SD
SMTP_USE_TLS=true

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# Sinalite API
SINALITE_CLIENT_ID=your_sinalite_client_id_here
SINALITE_CLIENT_SECRET=your_sinalite_client_secret_here
SINALITE_BASE_URL_DEV=https://api.sinaliteuppy.com
SINALITE_BASE_URL=https://api.sinaliteuppy.com

# Supabase Storage
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_BUCKET=gopostalsd-uploads

# Square Payment
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_APPLICATION_ID=your_square_application_id_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ENVIRONMENT=sandbox

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key (generate a secure random string)
JWT_SECRET_KEY=your_jwt_secret_key_here

# Session Configuration
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Rate limiting backend
# AUTH_RATE_LIMIT_STORE: memory, redis, or auto
AUTH_RATE_LIMIT_STORE=memory
# Redis URL for distributed rate limiting (required when AUTH_RATE_LIMIT_STORE=redis)
RATE_LIMIT_REDIS_URL=

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Sentry Error Tracking (optional)
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Debug mode (set to false in production)
DEBUG=true

# Flask secret key
SECRET_KEY=your_flask_secret_key_here

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Uncomment and configure for production deployment

# # Frontend URL for production
# FRONTEND_URL=https://gopostalsd.com

# # Database for production
# DATABASE_URL=postgresql://username:password@localhost:5432/gopostalsd

# # Email for production
# MAILERSEND_API_KEY=your_production_mailersend_key
# MAILERSEND_FROM_EMAIL=noreply@gopostalsd.com
# MAILERSEND_FROM_NAME=Go Postal SD

# # Security for production
# SESSION_COOKIE_SECURE=true
# DEBUG=false

# # Monitoring for production
# SENTRY_DSN=your_production_sentry_dsn
# LOG_LEVEL=WARNING

# # Production admin bootstrap (optional)
# When both are set, startup creates John Doe as Admin if that email does not exist.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your_secure_password_here
